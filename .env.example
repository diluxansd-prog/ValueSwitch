# Database (Neon Postgres in production, file URL for local SQLite dev)
DATABASE_URL="postgres://user:pass@host/db?sslmode=require"

# NextAuth.js
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Cron secret (Vercel sends `Authorization: Bearer <CRON_SECRET>` to /api/cron/*)
CRON_SECRET="generate-a-second-random-secret"

# Email — Resend transactional sender. Without these the system silently
# no-ops (logs in dev, returns { skipped: 'no-api-key' } in prod).
RESEND_API_KEY=""
EMAIL_FROM="ValueSwitch <hello@valueswitch.co.uk>"

# Awin combined feed (one URL, multiple FIDs, served by Sunday cron)
AWIN_COMBINED_FEED_URL=""

# Awin Publisher Reports API (powers /admin/revenue dashboard)
# These are DIFFERENT from the data-feed apikey embedded in feed URLs.
# Generate at ui.awin.com → Account → API Credentials.
AWIN_API_TOKEN=""
AWIN_PUBLISHER_ID=""
